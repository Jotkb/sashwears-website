# ── Sanity CMS ───────────────────────────────────────────────────────────────
# Found at sanity.io → your project → API → Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Usually "production" or "development"
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with Editor or higher permissions
# sanity.io → your project → API → Tokens → Add API token
SANITY_API_TOKEN=your-sanity-api-token

# ── Paystack ─────────────────────────────────────────────────────────────────
# dashboard.paystack.com → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ── Site ─────────────────────────────────────────────────────────────────────
# The canonical production URL — no trailing slash
NEXT_PUBLIC_SITE_URL=https://sashwears.com
